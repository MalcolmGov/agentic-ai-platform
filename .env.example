# Agentic AI Platform — Environment Configuration
# Copy this to .env and fill in your values

# ─── Database ───────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/agentic_ai_platform?schema=public"

# ─── Authentication ─────────────────────────
JWT_SECRET="CHANGE_ME_TO_A_SECURE_RANDOM_STRING_MIN_64_CHARS"
JWT_EXPIRY="24h"
BCRYPT_SALT_ROUNDS="12"

# ─── LLM Providers ─────────────────────────
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# ─── Vector Database ────────────────────────
# Option 1: pgvector (uses DATABASE_URL)
# Option 2: Pinecone
PINECONE_API_KEY=""
PINECONE_INDEX=""
PINECONE_ENVIRONMENT=""

# ─── Redis (scheduler + cache) ──────────────
REDIS_URL="redis://localhost:6379"

# ─── Object Storage ─────────────────────────
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# ─── Email ──────────────────────────────────
SENDGRID_API_KEY=""
FROM_EMAIL="noreply@agenticai.com"

# ─── Billing ────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ─── Application ────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
LOG_LEVEL="info"
ENCRYPTION_KEY="CHANGE_ME_32_CHAR_AES_256_KEY__"

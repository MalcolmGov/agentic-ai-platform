}

enum TriggerType {
  MANUAL
  SCHEDULED
  WEBHOOK
  EVENT
  REALTIME
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum StepType {
  TRIGGER
  AGENT
  CONDITION
  ACTION
  INTEGRATION

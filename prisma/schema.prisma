// ─────────────────────────────────────────────
// Governance & Compliance
// ─────────────────────────────────────────────

model GovernanceModelCard {
  id              String   @id @default(cuid())
  agentId         String
  agent           Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  modelType       String
  version         String
  biasAssessment  Json     @default("{}")
  fairnessMetrics Json     @default("{}")
  dataSources     Json     @default("[]")
  limitations     String[]
  approvedBy      String?
  status          String   @default("draft") // draft, pending_review, approved, rejected
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([agentId])
}

model GovernanceDecision {
  id         String   @id @default(cuid())
  agentId    String
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  decision   String
  rationale  String   @db.Text
  impact     String
  decidedBy  String
  reviewedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@index([agentId])
}

model ComplianceReport {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  framework  String
  findings   Json     @default("[]")
  riskLevel  String   @default("low") // low, medium, high, critical
  periodDays Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@index([framework])
}

// ─────────────────────────────────────────────
// Drift Detection
// ─────────────────────────────────────────────

model DriftBaseline {
  id            String   @id @default(cuid())
  agentId       String
  agent         Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  metric        String
  baselineValue Float
  threshold     Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([agentId])
}

model DriftEvent {
  id            String   @id @default(cuid())
  agentId       String
  agent         Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  metric        String
  baselineValue Float
  currentValue  Float
  deviation     Float
  severity      String   @default("info") // info, warning, critical
  acknowledged  Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([agentId])
  @@index([severity])
}

// ─────────────────────────────────────────────
// Marketplace
// ─────────────────────────────────────────────

model MarketplaceListing {
  id             String               @id @default(cuid())
  name           String
  description    String               @db.Text
  category       String
  tags           String[]
  authorTenantId String
  authorTenant   Tenant               @relation("MarketplaceListings", fields: [authorTenantId], references: [id], onDelete: Cascade)
  version        String
  pricing        Json                 @default("{}")
  rating         Float                @default(0)
  installCount   Int                  @default(0)
  status         String               @default("draft") // draft, pending_review, published, suspended
  config         Json                 @default("{}")
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  reviews        MarketplaceReview[]
  installs       MarketplaceInstall[]

  @@index([authorTenantId])
  @@index([category])
  @@index([status])
}

model MarketplaceReview {
  id        String             @id @default(cuid())
  listingId String
  listing   MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String             @db.Text
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([listingId])
  @@index([tenantId])
}

model MarketplaceInstall {
  id        String             @id @default(cuid())
  listingId String
  listing   MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([listingId])
  @@index([tenantId])
}

// ─────────────────────────────────────────────
// Orchestrated Workflows
// ─────────────────────────────────────────────

model OrchestratedWorkflow {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?   @db.Text
  nodes       Json      @default("[]")
  edges       Json      @default("[]")
  status      String    @default("draft") // draft, running, completed, failed, paused, cancelled
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([status])
}

// ─────────────────────────────────────────────
// Prompt Versioning
// ─────────────────────────────────────────────

model PromptVersion {
  id            String   @id @default(cuid())
  agentId       String
  agent         Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  version       Int
  content       String   @db.Text
  message       String
  author        String
  branch        String   @default("main")
  tags          String[]
  parentVersion Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([agentId])
  @@index([agentId, version])
}

// ─────────────────────────────────────────────
// Webhooks
// ─────────────────────────────────────────────

model WebhookSubscription {
  id         String            @id @default(cuid())
  tenantId   String
  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  url        String
  secret     String
  events     String[]
  active     Boolean           @default(true)
  metadata   Json?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  deliveries WebhookDelivery[]

  @@index([tenantId])
}

model WebhookDelivery {
  id             String              @id @default(cuid())
  subscriptionId String
  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  event          String
  payload        Json
  status         String              @default("pending") // pending, delivered, failed, retrying
  attempts       Int                 @default(0)
  lastAttemptAt  DateTime?
  responseCode   Int?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([subscriptionId])
  @@index([status])
}

// ─────────────────────────────────────────────
// Team Invites
// ─────────────────────────────────────────────

model TeamInvite {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email      String
  role       String
  token      String    @unique
  invitedBy  String
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([tenantId])
  @@index([email])
}

// ─────────────────────────────────────────────
// Notifications
// ─────────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  category  String
  title     String
  message   String    @db.Text
  channels  String[]
  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId])
  @@index([userId])
  @@index([read])
}

// ─────────────────────────────────────────────
// SSO Configuration
// ─────────────────────────────────────────────

model SSOConfig {
  id             String   @id @default(cuid())
  tenantId       String   @unique
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider       String
  protocol       String // SAML, OIDC
  config         Json     @default("{}")
  active         Boolean  @default(false)
  allowedDomains String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─────────────────────────────────────────────
// White-Label Configuration
// ─────────────────────────────────────────────

model WhiteLabelConfig {
  id             String   @id @default(cuid())
  tenantId       String   @unique
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  theme          Json     @default("{}")
  customDomain   String?
  domainVerified Boolean  @default(false)
  emailBranding  Json?
  loginPage      Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─────────────────────────────────────────────
// Onboarding Progress
// ─────────────────────────────────────────────

model OnboardingProgress {
  id     String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  /// Full wizard v2 state (see lib/onboarding/wizard-schema)
  payload Json @default("{}")

  /// Denormalized for list queries: wizard reached success / skipped
  done           Boolean  @default(false)
  /// Last active step 1…9
  currentStep    String   @default("1")
  completedSteps String[] @default([])

  startedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// Markets & Apps
// ─────────────────────────────────────────────

model Market {
  id                  String        @id @default(cuid())
  code                String        @unique // 'za', 'ng', 'ke' etc
  name                String
  flag                String
  region              String
  status              String        @default("coming_soon")
  currencyCode        String
  dataResidencyLaw    String
  dataResidencyRegion String
  complianceNotes     String?
  isActive            Boolean       @default(false)
  tenantId            String
  tenant              Tenant        @relation(fields: [tenantId], references: [id])
  apps                AppProperty[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([tenantId])
}

model AppProperty {
  id                 String            @id @default(cuid())
  name               String
  shortName          String
  type               String // website, mobile-ios, mobile-android, internal-portal, api, whatsapp, ussd
  description        String
  marketId           String
  market             Market            @relation(fields: [marketId], references: [id])
  ownerDivision      String
  sharedWith         String[] // division IDs
  status             String            @default("development")
  url                String?
  identifier         String?
  integrationMethods String[] // integration method IDs
  color              String            @default("#3b82f6")
  tenantId           String
  tenant             Tenant            @relation(fields: [tenantId], references: [id])
  deployments        AgentDeployment[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([tenantId])
  @@index([marketId])
}

model AgentDeployment {
  id            String       @id @default(cuid())
  instanceId    String       @unique @default(cuid())
  templateId    String
  name          String
  department    String
  icon          String       @default("🤖")
  color         String       @default("#3b82f6")
  status        String       @default("active") // active, pending, paused, error
  markets       String[] // market codes e.g. ['za', 'ng']
  appIds        String[] // AppProperty IDs
  deployedBy    String // user email
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id])
  appProperty   AppProperty? @relation(fields: [appPropertyId], references: [id])
  appPropertyId String?
  runCount      Int          @default(0)
  lastRunAt     DateTime?
  config        Json         @default("{}")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([tenantId])
  @@index([templateId])
}

// ─────────────────────────────────────────────
// Reseller / White-Label Partner System
// ─────────────────────────────────────────────

model Reseller {
  id             String         @id @default(cuid())
  name           String
  slug           String         @unique
  contactEmail   String
  contactName    String
  status         ResellerStatus @default(PENDING)
  tier           ResellerTier   @default(STANDARD)
  commissionRate Float          @default(0.20)
  clientLimit    Int            @default(10)
  totalMRR       Float          @default(0)
  totalClients   Int            @default(0)
  contractStart  DateTime?
  contractEnd    DateTime?
  notes          String?        @db.Text
  onboardedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  clients     ResellerClient[]
  commissions ResellerCommission[]
}

model ResellerClient {
  id         String   @id @default(cuid())
  resellerId String
  reseller   Reseller @relation(fields: [resellerId], references: [id], onDelete: Cascade)
  tenantId   String   @unique
  mrr        Float    @default(0)
  plan       String   @default("STARTER")
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([resellerId])
}

model ResellerCommission {
  id         String    @id @default(cuid())
  resellerId String
  reseller   Reseller  @relation(fields: [resellerId], references: [id], onDelete: Cascade)
  month      String
  revenue    Float
  commission Float
  status     String    @default("pending")
  paidAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([resellerId])
  @@index([month])
}

enum ResellerStatus {
  PENDING
  ACTIVE
  SUSPENDED
  CHURNED
}

enum ResellerTier {
  STANDARD
  SILVER
  GOLD
  PLATINUM
}
